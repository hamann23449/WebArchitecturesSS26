generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Prisma schema for Album Ratings app
// Models: User, Artist, Genre (optional), Album, Rating

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  ratings       Rating[]
}

model Artist {
  id     Int     @id @default(autoincrement())
  name   String
  albums Album[]
}

model Genre {
  id     Int     @id @default(autoincrement())
  name   String
  albums Album[]
}

model Album {
  id           Int      @id @default(autoincrement())
  title        String
  artist       Artist   @relation(fields: [artistId], references: [id])
  artistId     Int
  genre        Genre?   @relation(fields: [genreId], references: [id])
  genreId      Int?
  release_year Int?
  ratings      Rating[]
}

model Rating {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  album       Album    @relation(fields: [albumId], references: [id])
  albumId     Int
  rating      Int
  review_text String?
  created_at  DateTime @default(now())

  @@index([userId])
  @@index([albumId])

}
